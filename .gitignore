# Specific ignores for the B.M.O junction
B.M.O/.vscode/
B.M.O/assets/

# If you also want to ignore assets in the other folder you mentioned earlier


# Logs
BMO/logs
BMO/*.log
BMO/npm-debug.log*
BMO/yarn-debug.log*
BMO/yarn-error.log*
BMO/lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
BMO/report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
BMO/pids
BMO/*.pid
BMO/*.seed
BMO/*.pid.lock
BMO/.DS_Store

# Directory for instrumented libs generated by jscoverage/JSCover
BMO/lib-cov

# Coverage directory used by tools like istanbul
BMO/coverage
BMO/*.lcov

# nyc test coverage
BMO/.nyc_output

# node-waf configuration
BMO/.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
BMO/build/Release

# Dependency directories
BMO/node_modules/
BMO/jspm_packages/

# TypeScript v1 declaration files
BMO/typings/

# TypeScript cache
BMO/*.tsbuildinfo

# Optional npm cache directory
BMO/.npm

# Optional eslint cache
BMO/.eslintcache

# Optional REPL history
BMO/.node_repl_history

# Output of 'npm pack'
BMO/*.tgz

# Yarn Integrity file
BMO/.yarn-integrity

# dotenv environment variables file
BMO/.env
BMO/.env.test

# parcel-bundler cache (https://parceljs.org/)
BMO/.cache

# next.js build output
BMO/.next

# nuxt.js build output
BMO/.nuxt

# vuepress build output
BMO/.vuepress/dist

# Serverless directories
BMO/.serverless/

# FuseBox cache
BMO/.fusebox/

# DynamoDB Local files
BMO/.dynamodb/

# Webpack
BMO/.webpack/

# Vite
BMO/.vite/

# Electron-Forge
BMO/out/

